# ──────────────────────────────────────────────
# Twilio — WhatsApp API
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
# Número de WhatsApp de Twilio (sandbox: whatsapp:+14155238886)
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# ──────────────────────────────────────────────
# Notion API
# ──────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_key
# ID de la base de datos de tareas (de la URL de Notion)
NOTION_TASKS_DB_ID=your_tasks_database_id
# ID de la base de datos de proyectos (opcional)
NOTION_PROJECTS_DB_ID=your_projects_database_id

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Números permitidos (whitelist, separados por coma)
# Dejar vacío para permitir todos los números
# Formato: whatsapp:+1234567890,whatsapp:+0987654321
ALLOWED_NUMBERS=
