# =============================================================
# Notion LATAM Website — Variables de entorno
# =============================================================
# Copia este archivo a .env.local y rellena los valores

# URL del sitio (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://notionlatam.com

# Google Analytics 4 — Measurement ID (formato: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# Notion API (para integraciones futuras del bot o dashboard)
NOTION_API_KEY=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_DATABASE_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email (Resend API para formulario de contacto)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=hello@notionlatam.com

# Stripe (para pagos de templates/cursos)
# Obtén tus keys en https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# WhatsApp Bot (Twilio)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
